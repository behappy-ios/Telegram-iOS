include "StickerPackReference.fbs";

namespace IosappCore;

table IosappMediaFileAttribute_FileName {
    fileName:string (id: 0, required);
}

table StickerMaskCoords {
    n:int32 (id: 0);
    x:float32 (id: 1); 
    y:float32 (id: 2);
    zoom:float32 (id: 3);
}

table IosappMediaFileAttribute_Sticker {
    displayText:string (id: 0, required);
    packReference:StickerPackReference (id: 1);
    maskData:StickerMaskCoords (id: 2);
}

table IosappMediaFileAttribute_ImageSize {
    width:int32 (id: 0);
    height:int32 (id: 1);
}

table IosappMediaFileAttribute_Animated {
}

table IosappMediaFileAttribute_Video {
    duration:float32 (id: 0);
    width:int32 (id: 1);
    height:int32 (id: 2);
    flags:int32 (id: 3);
    preloadSize:int32 (id: 4);
    coverTime:float32 (id: 5);
    videoCodec:string (id: 6);
}

table IosappMediaFileAttribute_Audio {
    isVoice:bool (id: 0);
    duration:int32 (id: 1);
    title:string (id: 2);
    performer:string (id: 3);
    waveform:[ubyte] (id: 4);
}

table IosappMediaFileAttribute_HasLinkedStickers {
}

table IosappMediaFileAttribute_HintFileIsLarge {
}

table IosappMediaFileAttribute_HintIsValidated {
}

table IosappMediaFileAttribute_NoPremium {
}

table IosappMediaFileAttribute_CustomEmoji {
    isPremium:bool (id: 0);
    isSingleColor:bool (id: 1);
    alt:string (id: 2, required);
    packReference:StickerPackReference (id: 3);
}

union IosappMediaFileAttribute_Value {
    IosappMediaFileAttribute_FileName,
    IosappMediaFileAttribute_Sticker,
    IosappMediaFileAttribute_ImageSize,
    IosappMediaFileAttribute_Animated,
    IosappMediaFileAttribute_Video,
    IosappMediaFileAttribute_Audio,
    IosappMediaFileAttribute_HasLinkedStickers,
    IosappMediaFileAttribute_HintFileIsLarge,
    IosappMediaFileAttribute_HintIsValidated,
    IosappMediaFileAttribute_NoPremium,
    IosappMediaFileAttribute_CustomEmoji
}

table IosappMediaFileAttribute {
    value:IosappMediaFileAttribute_Value (id: 1, required);
}

root_type IosappMediaFileAttribute;
